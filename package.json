{
  "name": "links",
  "description": "Links de redes sociais, canais e de contato do Eskimozin",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node register.build.js && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint src/**/*.js src/**/*.jsx --fix",
    "preview": "vite preview",
    "deploy": "node register.build.js && vite build && gh-pages -d dist",
    "cy:run": "cypress run",
    "test": "cypress run",
    "update": "npm update --legacy-peer-deps",
    "ci:test": "start-server-and-test dev http://localhost:5173 test",
    "upgrade:deps": "npx npm-check-updates -u && npm install --legacy-peer-deps",
    "cypress": "npx cypress run",
    "sync:version": "git pull && node sync-version.js"
  },
  "dependencies": {
    "@semantic-release/changelog": "^7.0.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^11.0.0",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "aos": "^2.3.4",
    "bootstrap": "^5.3.8",
    "moment": "^2.30.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.8",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.8",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "cypress": "^15.19.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "start-server-and-test": "^3.0.11",
    "vite": "^8.1.5"
  },
  "allowScripts": {
    "cypress@15.18.1": true,
    "esbuild@0.21.5": true
  }
}
